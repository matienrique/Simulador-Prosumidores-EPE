rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: feedback
    // Document ID: auto-generated
    // Fields:
    //   - choice: string ('yes' or 'no') - required
    //   - comments: string - optional
    //   - userType: string - required
    //   - userTypeLabel: string - required
    //   - timestamp: string (ISO 8601) - required
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "matienrique27@gmail.com" && request.auth.token.email_verified == true));
    }
    
    function isValidFeedback(data) {
      return data.keys().hasAll(['choice', 'userType', 'userTypeLabel', 'timestamp']) &&
             data.choice in ['yes', 'no'] &&
             data.userType is string &&
             data.userTypeLabel is string &&
             data.timestamp is string &&
             (!('comments' in data) || (data.comments is string && data.comments.size() < 2000));
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /feedback/{feedbackId} {
      // Anyone can submit feedback, but it must be valid
      allow create: if isValidFeedback(request.resource.data);
      
      // Only admins can read, update, or delete feedback
      allow read, update, delete: if isAdmin();
    }
    
    match /users/{userId} {
      // Only the user can read their own profile, admins can read all
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      
      // Only admins can create/update user roles
      allow create, update: if isAdmin();
    }
  }
}
