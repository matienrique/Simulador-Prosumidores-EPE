rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isValidFeedback(data) {
      return data.keys().hasAll(['number', 'date', 'userType', 'resolved']) &&
             data.number is int &&
             data.date is string &&
             data.userType is string &&
             data.resolved is bool &&
             (!('observations' in data) || data.observations is string);
    }

    function isValidStats(data) {
      return data.keys().hasAll(['visitCount', 'resolvedCount', 'notResolvedCount', 'lastConsultationNumber']) &&
             data.visitCount is int &&
             data.resolvedCount is int &&
             data.notResolvedCount is int &&
             data.lastConsultationNumber is int;
    }

    // Feedback collection
    match /tabla_estadisticas/{feedbackId} {
      // Allow anyone to create feedback
      allow create: if isValidFeedback(request.resource.data);
      // Allow anyone to read feedback (UI will handle password protection)
      allow read: if true;
      // Allow anyone to update/delete (for the "Borrar datos" feature)
      allow update, delete: if true;
    }

    // Global stats collection
    match /global_stats/{statsId} {
      // Allow anyone to read and update counters
      allow read: if true;
      allow create, update: if isValidStats(request.resource.data);
      allow delete: if true;
    }
  }
}
