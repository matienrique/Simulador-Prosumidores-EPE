rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: feedback
    // Document ID: auto-generated
    // Fields:
    //   - choice: string (optional, 'yes'|'no'|null)
    //   - observation: string (optional, max 1000 chars)
    //   - userType: string (required)
    //   - userTypeLabel: string (optional)
    //   - totalEpe: number (required)
    //   - totalProsumidor: number (required)
    //   - savings: number (required)
    //   - timestamp: timestamp (required)
    //   - uid: string (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "matienrique27@gmail.com" && request.auth.token.email_verified == true));
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidFeedback(data) {
      return hasRequiredFields(['userType', 'totalEpe', 'totalProsumidor', 'savings', 'timestamp', 'uid']) &&
             hasOnlyAllowedFields(['choice', 'observation', 'userType', 'userTypeLabel', 'totalEpe', 'totalProsumidor', 'savings', 'timestamp', 'uid']) &&
             (data.choice == null || data.choice in ['yes', 'no']) &&
             (!('observation' in data) || (data.observation is string && data.observation.size() <= 1000)) &&
             data.userType is string &&
             data.totalEpe is number &&
             data.totalProsumidor is number &&
             data.savings is number &&
             data.timestamp is timestamp &&
             data.uid is string;
    }

    match /feedback/{feedbackId} {
      // Allow anyone authenticated (including anonymous) to create feedback
      allow create: if isAuthenticated() && isValidFeedback(request.resource.data) && request.resource.data.uid == request.auth.uid;
      
      // Only admins can read all feedback
      allow read: if isAdmin();
      
      // No updates or deletes allowed for now to maintain integrity
      allow update, delete: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isAuthenticated() && request.auth.uid == userId;
      allow write: if isAdmin();
    }
  }
}
