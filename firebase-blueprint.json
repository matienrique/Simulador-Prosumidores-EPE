{
  "entities": {
    "Feedback": {
      "title": "Feedback",
      "description": "User feedback and calculation data",
      "type": "object",
      "properties": {
        "timestamp": {
          "type": "string",
          "format": "date-time",
          "description": "When the feedback was submitted"
        },
        "userType": {
          "type": "string",
          "description": "Type of user (Prosumidor, No Prosumidor, etc.)"
        },
        "mode": {
          "type": "string",
          "description": "Calculation mode"
        },
        "totalEpe": {
          "type": "number",
          "description": "Total EPE amount"
        },
        "totalProsumidor": {
          "type": "number",
          "description": "Total Prosumidor amount"
        },
        "savings": {
          "type": "number",
          "description": "Total savings"
        },
        "observation": {
          "type": "string",
          "description": "User observation text"
        }
      },
      "required": ["timestamp", "userType", "totalEpe", "totalProsumidor"]
    }
  },
  "firestore": {
    "/feedback/{feedbackId}": {
      "schema": "Feedback",
      "description": "Collection of user feedback"
    }
  }
}
