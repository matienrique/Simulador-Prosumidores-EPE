{
  "entities": {
    "feedback": {
      "title": "Feedback",
      "description": "User feedback about the simulator results",
      "type": "object",
      "properties": {
        "choice": {
          "type": "string",
          "enum": ["yes", "no"],
          "description": "Whether the user resolved their query"
        },
        "comments": {
          "type": "string",
          "description": "User's observations or comments"
        },
        "userType": {
          "type": "string",
          "description": "The internal UserType enum value"
        },
        "userTypeLabel": {
          "type": "string",
          "description": "A human-readable label for the user type"
        },
        "timestamp": {
          "type": "string",
          "format": "date-time",
          "description": "When the feedback was submitted"
        }
      },
      "required": ["choice", "userType", "userTypeLabel", "timestamp"]
    }
  },
  "firestore": {
    "/feedback/{feedbackId}": {
      "schema": "feedback",
      "description": "Collection of user feedback entries"
    }
  }
}
